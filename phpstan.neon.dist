# PHPStan configuration for Serial Number Bundle.
#
# Static analysis on src/ and tests/ (level 8).
# Run: make phpstan
parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - demo/*
        - vendor/*
    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
